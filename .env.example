# Telegram bot (BotFather → /newbot)
# IMPORTANT (AD-6): Same token as 02_audit_safe_signals (single Telegram interface).
# 03 owns long-polling, 02 only sends. Do not start a second long-poll process.
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to use the bot.
# Get yours by messaging @userinfobot on Telegram.
TELEGRAM_AUTHORIZED_CHAT_IDS=

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# 02_audit_safe_signals read endpoint (ADR-0003 Option B 1차 데이터 소스)
# Fly.io 배포 후 https://audit-safe-signals.fly.dev/ 등으로 변경
AUDIT_SIGNALS_BASE_URL=https://audit-safe-signals.fly.dev
AUDIT_SIGNALS_SECRET=

# TradingView Desktop CDP (선택 — 스크린샷 등 부수 기능에만 필요)
TV_DEBUG_PORT=9222

# Path to cloned tradingview-mcp server entry point (선택)
TV_MCP_SERVER_PATH=/Users/your-user/code/tradingview-mcp/src/server.js

# Optional — Claude model for analysis
ANTHROPIC_MODEL=claude-sonnet-4-6
