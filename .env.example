# Telegram bot (BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to use the bot.
# Get yours by messaging @userinfobot on Telegram.
TELEGRAM_AUTHORIZED_CHAT_IDS=

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# TradingView Desktop CDP debug port
TV_DEBUG_PORT=9222

# Path to cloned tradingview-mcp server entry point
TV_MCP_SERVER_PATH=/Users/your-user/code/tradingview-mcp/src/server.js

# Optional — Claude model for analysis
ANTHROPIC_MODEL=claude-sonnet-4-6
